# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.105

# Database (local dev uses SQLite when USE_POSTGRES=False)
USE_POSTGRES=False
DB_NAME=asset_tracking
DB_USER=asset_user
DB_PASSWORD=change-me
DB_HOST=localhost
DB_PORT=5432

# reCAPTCHA v2 checkbox ("I'm not a robot") — https://www.google.com/recaptcha/admin
# Key type MUST be: reCAPTCHA v2 → "I'm not a robot" Checkbox (NOT v3)
#
# Real keys only work on domains listed in Google admin:
#   localhost, 127.0.0.1, yourdomain.com
# Private IPs (192.168.x.x) CANNOT be added — use Google test keys for phone dev
#
# Test keys (dev only, work everywhere):
# RECAPTCHA_PUBLIC_KEY=6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI
# RECAPTCHA_PRIVATE_KEY=6LeIxAcTAAAAAGG-vFI1TnRWxMZNFuojJ4WifJWe
RECAPTCHA_PUBLIC_KEY=your-recaptcha-site-key
RECAPTCHA_PRIVATE_KEY=your-recaptcha-secret-key

# IMPORTANT: Do not duplicate DEBUG/ALLOWED_HOSTS below — last value wins and breaks local dev.
# DEBUG=True
# ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.105
# CSRF_TRUSTED_ORIGINS=https://localhost:8443,https://127.0.0.1:8443,https://192.168.1.105:8443,http://127.0.0.1:8000

# Production (Vultr) — replace local values above when deploying:
# DEBUG=False
# SECURE_SSL_REDIRECT=True
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Gmail — site asset report emails (PDF attachment)
# Use a Google App Password: https://myaccount.google.com/apppasswords
# EMAIL_HOST_USER=yourname@gmail.com
# EMAIL_HOST_PASSWORD=xxxx-xxxx-xxxx-xxxx
# DEFAULT_FROM_EMAIL=yourname@gmail.com
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
